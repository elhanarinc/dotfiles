// Zed settings
{
  // ─── Theme ────────────────────────────────────────────────────────────────
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  },

  // ─── Fonts ────────────────────────────────────────────────────────────────
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_size": 14,
  "ui_font_size": 14,

  // ─── Editor ───────────────────────────────────────────────────────────────
  "base_keymap": "VSCode",
  "soft_wrap": "editor_width",
  "wrap_guides": [150],
  "show_wrap_guides": true,
  "detect_indent": false,
  "tab_size": 4,
  "indent_guides": {
    "enabled": true
  },
  "minimap": {
    "show": "auto"
  },
  "scrollbar": {
    "show": "auto",
    "git_diff": true,
    "search_results": true,
    "diagnostics": "all"
  },

  // ─── Save ─────────────────────────────────────────────────────────────────
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "formatter": "auto",
  "format_on_save": "on",
  "ensure_final_newline_on_save": true,
  "remove_trailing_whitespace_on_save": true,

  // ─── File scan ────────────────────────────────────────────────────────────
  "file_scan_exclusions": [
    "**/.git",
    "**/.DS_Store",
    "**/node_modules",
    "**/__pycache__",
    "**/.venv",
    "**/venv",
    "**/target",
    "**/.build"
  ],

  // ─── Project panel ────────────────────────────────────────────────────────
  "project_panel": {
    "dock": "left",
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "auto_reveal_entries": true,
    "auto_fold_dirs": true
  },

  // ─── Diff view ────────────────────────────────────────────────────────────
  // "unified" = inline/VS Code style, "split" = side-by-side
  "diff_view_style": "unified",

  // ─── Git ──────────────────────────────────────────────────────────────────
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "tabs": {
    "git_status": false
  },
  "title_bar": {
    "show_branch_icon": false
  },

  // ─── Terminal ─────────────────────────────────────────────────────────────
  "terminal": {
    "shell": {
      "program": "/bin/zsh"
    },
    "font_family": "JetBrains Mono",
    "font_size": 15,
    "working_directory": "current_project_directory",
    "option_as_meta": true,
    "env": {
      "TERM": "xterm-256color",
      "COLORTERM": "truecolor"
    }
  },

  // ─── AI Agent ─────────────────────────────────────────────────────────────
  // default_model: copilot_chat (GitHub Copilot — no separate API key needed)
  // commit_message_model: zed.dev (Zed account — free 50/month)
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5"
    },
    "commit_message_model": {
      "provider": "zed.dev",
      "model": "claude-3-5-haiku"
    },
    "button": true,
    "dock": "right"
  },

  // ─── Language formatters ──────────────────────────────────────────────────
  "languages": {
    "Go": {
      "formatter": {
        "external": {
          "command": "goimports",
          "arguments": []
        }
      },
      "format_on_save": "on",
      "tab_size": 4
    },
    "Python": {
      "formatter": {
        "external": {
          "command": "autopep8",
          "arguments": ["-"]
        }
      },
      "format_on_save": "on",
      "tab_size": 4
    },
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      },
      "format_on_save": "on",
      "tab_size": 2
    },
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      },
      "format_on_save": "on",
      "tab_size": 2
    },
    "TSX": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      },
      "format_on_save": "on",
      "tab_size": 2
    },
    "JSON": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      },
      "format_on_save": "on",
      "tab_size": 2
    },
    "YAML": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"]
        }
      },
      "format_on_save": "on",
      "tab_size": 2
    },
    "Dockerfile": {
      "format_on_save": "off"
    },
    "Markdown": {
      "soft_wrap": "editor_width",
      "format_on_save": "off"
    }
  },

  // ─── LSP ──────────────────────────────────────────────────────────────────
  // pythonPath: pyenv shim — works across machines (no hardcoded version)
  "lsp": {
    "pyright": {
      "settings": {
        "python": {
          "pythonPath": "~/.pyenv/shims/python"
        }
      }
    }
  },

  // ─── Session ──────────────────────────────────────────────────────────────
  "session": {
    "trust_all_worktrees": true
  },

  // ─── Telemetry ────────────────────────────────────────────────────────────
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },

  // ─── Agent servers (MCP) ──────────────────────────────────────────────────
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    },
    "opencode": {
      "favorite_models": [
        "opencode/qwen3.6-plus-free",
        "opencode/minimax-m2.5-free"
      ],
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    }
  }
}
