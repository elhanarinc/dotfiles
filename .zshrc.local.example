# ~/.zshrc.local — Machine-specific configuration
# Copy this file to ~/.zshrc.local and customize for this machine.
# This file is sourced at the END of ~/.zshrc and is NOT tracked in git.
# Use it for: API keys, machine-specific paths, and work-only settings.

# ============================================================
# SECRETS — never commit these to git
# ============================================================
# export GEMINI_API_KEY="your-api-key-here"
# export OPENAI_API_KEY="your-api-key-here"
# export ANTHROPIC_API_KEY="your-api-key-here"
# export AWS_ACCESS_KEY_ID="your-key"
# export AWS_SECRET_ACCESS_KEY="your-secret"
# export NPM_TOKEN="your-npm-token"

# ============================================================
# Work / org-specific config
# ============================================================
# export GOPRIVATE="github.com/your-org/*"
# export GOPROXY="direct"

# Suppress library warnings specific to this machine
# export PYTHONWARNINGS="ignore::UserWarning:packaging._manylinux"

# ============================================================
# Google Cloud SDK
# ============================================================
# if [ -f "$HOME/google-cloud-sdk/path.zsh.inc" ]; then
#   source "$HOME/google-cloud-sdk/path.zsh.inc"
# fi
# if [ -f "$HOME/google-cloud-sdk/completion.zsh.inc" ]; then
#   source "$HOME/google-cloud-sdk/completion.zsh.inc"
# fi

# ============================================================
# Machine-specific tool paths
# ============================================================

# Windsurf / Codeium
# export PATH="/Users/$USER/.codeium/windsurf/bin:$PATH"

# Antigravity
# export PATH="/Users/$USER/.antigravity/antigravity/bin:$PATH"

# OpenCode
# export PATH="/Users/$USER/.opencode/bin:$PATH"

# JetBrains Toolbox scripts
# export PATH="$HOME/Library/Application Support/JetBrains/Toolbox/scripts:$PATH"

# ============================================================
# Starship config override (if using a different config on this machine)
# ============================================================
# export STARSHIP_CONFIG="$HOME/.config/starship-work.toml"

# ============================================================
# kubectl context default namespace overrides
# ============================================================
# alias kdev='kubectl config use-context dev-cluster'
# alias kprod='kubectl config use-context prod-cluster'
