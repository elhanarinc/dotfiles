// Zed settings
{
    // ─── Fonts ────────────────────────────────────────────────────────────────
    "agent_servers": {
        "opencode": {
            "favorite_models": [
                "opencode/minimax-m2.5-free",
                "opencode/qwen3.6-plus-free/medium"
            ],
            "type": "registry"
        },
        "codex-acp": {
            "type": "registry"
        },
        "claude-acp": {
            "type": "registry"
        }
    },
    "buffer_font_size": 13,
    "ui_font_size": 13,

    // ─── Editor ───────────────────────────────────────────────────────────────
    "base_keymap": "VSCode",
    "soft_wrap": "editor_width",
    "wrap_guides": [150],
    "show_wrap_guides": true,
    "tab_size": 4,
    "indent_guides": {
        "enabled": true,
    },
    "minimap": {
        "show": "auto",
    },
    "scrollbar": {
        "show": "auto",
        "git_diff": true,
        "search_results": true,
        "diagnostics": "all",
    },

    // ─── Save ─────────────────────────────────────────────────────────────────
    "autosave": {
        "after_delay": {
            "milliseconds": 1000,
        },
    },
    "formatter": "auto",
    "format_on_save": "on",
    "ensure_final_newline_on_save": true,
    "remove_trailing_whitespace_on_save": true,

    // ─── File scan ────────────────────────────────────────────────────────────
    "file_scan_exclusions": [
        "**/.git",
        "**/.DS_Store",
        "**/node_modules",
        "**/__pycache__",
        "**/.venv",
        "**/venv",
        "**/target",
        "**/.build",
    ],

    // ─── Project panel ────────────────────────────────────────────────────────
    "project_panel": {
        "dock": "left",
        "file_icons": true,
        "folder_icons": true,
        "git_status": true,
        "auto_reveal_entries": true,
        "auto_fold_dirs": true,
    },

    // ─── Diff view ────────────────────────────────────────────────────────────
    // "unified" = inline/VS Code style, "split" = side-by-side
    "diff_view_style": "unified",

    // ─── Git ──────────────────────────────────────────────────────────────────
    "git": {
        "inline_blame": {
            "enabled": false,
        },
    },
    "tabs": {
        "git_status": false,
    },
    "title_bar": {
        "show_branch_icon": false,
    },

    // ─── Terminal ─────────────────────────────────────────────────────────────
    "terminal": {
        "shell": {
            "program": "/bin/zsh",
        },
        "font_size": 15,
        "working_directory": "current_project_directory",
        "option_as_meta": true,
        "env": {
            "TERM": "xterm-256color",
            "COLORTERM": "truecolor",
        },
    },

    // ─── Language formatters ──────────────────────────────────────────────────
    "languages": {
        "Go": {
            "formatter": {
                "external": {
                    "command": "goimports",
                    "arguments": [],
                },
            },
            "format_on_save": "on",
            "tab_size": 4,
        },
        "Python": {
            "formatter": {
                "external": {
                    "command": "autopep8",
                    "arguments": ["-"],
                },
            },
            "format_on_save": "on",
            "tab_size": 4,
        },
        "JavaScript": {
            "formatter": {
                "external": {
                    "command": "prettier",
                    "arguments": ["--stdin-filepath", "{buffer_path}"],
                },
            },
            "format_on_save": "on",
            "tab_size": 2,
        },
        "TypeScript": {
            "formatter": {
                "external": {
                    "command": "prettier",
                    "arguments": ["--stdin-filepath", "{buffer_path}"],
                },
            },
            "format_on_save": "on",
            "tab_size": 2,
        },
        "TSX": {
            "formatter": {
                "external": {
                    "command": "prettier",
                    "arguments": ["--stdin-filepath", "{buffer_path}"],
                },
            },
            "format_on_save": "on",
            "tab_size": 2,
        },
        "JSON": {
            "formatter": {
                "external": {
                    "command": "prettier",
                    "arguments": ["--stdin-filepath", "{buffer_path}"],
                },
            },
            "format_on_save": "on",
            "tab_size": 2,
        },
        "YAML": {
            "formatter": {
                "external": {
                    "command": "prettier",
                    "arguments": ["--stdin-filepath", "{buffer_path}"],
                },
            },
            "format_on_save": "on",
            "tab_size": 2,
        },
        "Dockerfile": {
            "format_on_save": "off",
        },
        "Markdown": {
            "soft_wrap": "editor_width",
            "format_on_save": "off",
        },
    },

    // ─── LSP ──────────────────────────────────────────────────────────────────
    // pythonPath: pyenv shim — works across machines (no hardcoded version)
    "lsp": {
        "pyright": {
            "settings": {
                "python": {
                    "pythonPath": "~/.pyenv/shims/python",
                },
            },
        },
    },

    // ─── Session ──────────────────────────────────────────────────────────────
    "session": {
        "trust_all_worktrees": true,
    },

    // ─── Agent ────────────────────────────────────────────────────────────────
    "agent": {
        "commit_message_model": {
            "provider": "zed.dev",
            "model": "claude-sonnet-4-5",
        },
    },

    // ─── Telemetry ────────────────────────────────────────────────────────────
    "telemetry": {
        "diagnostics": false,
        "metrics": false,
    },
}
